# Configuration Serveur YOOL Station Server

# Port du serveur
PORT=3000

# Base de Données MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=yool_station_db
DB_PORT=3306

# Sécurité JWT
JWT_SECRET=super_secret_jwt_key_yool_2024
JWT_EXPIRES_IN=24h

# Configuration Module 1 (API Externe)
MODULE1_API_URL=https://api.module1.yool.com
MODULE1_API_KEY=your_module1_api_key

# Logs
LOG_LEVEL=info

# Environnement
NODE_ENV=development
