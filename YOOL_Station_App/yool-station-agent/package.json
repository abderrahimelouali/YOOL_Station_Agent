{
  "name": "yool-scan-station",
  "version": "1.0.0",
  "description": "Client Electron pour YOOL Station - Contrôle d'accès",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build --outDir dist/renderer && electron-builder"
  },
  "keywords": [
    "electron",
    "react",
    "kiosk",
    "access-control"
  ],
  "author": "YOOL Team",
  "license": "ISC",
  "build": {
    "appId": "com.yool.station",
    "productName": "YOOL Scan Station",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "renderer/assets/yool-icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-is-dev": "^2.0.0",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^4.0.0"
  }
}
