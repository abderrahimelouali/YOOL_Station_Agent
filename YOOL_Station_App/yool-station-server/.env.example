# Port du serveur
PORT=3000

# Base de Données MySQL (XAMPP)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=yool_station_agent
DB_PORT=3306

# Sécurité JWT (Minimum 32 caractères pour HS256)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=60s

# Module 1 (External Auth Service)
MODULE1_API_URL=http://localhost:3001/api
MODULE1_SERVER_SECRET=your_server_master_key_here

# Webhook de déconnexion Laravel
PLATFORM_LOGOUT_URL=http://127.0.0.1:8000/api/sso/logout

# Logs
LOG_LEVEL=info

# Environnement
NODE_ENV=development
DEFAULT_STATION_LOCATION=Tinghir
