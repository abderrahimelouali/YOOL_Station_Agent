# Configuration Client YOOL Station Agent

# URL du serveur YOOL Station Server
VITE_API_URL=http://localhost:3000/api

# Identifiant unique de ce poste (généré à l'install ou fixé)
STATION_ID=STATION_001

# Clé secrète pour signature interne (facultatif si uniquement JWT serveur)
CLIENT_SECRET=change_me_client_secret

# Timeout de verrouillage (minutes)
INACTIVITY_TIMEOUT=15

# Mode de dev
NODE_ENV=development
