# =============================================================================
# YOOL STATION SERVER - ENV TEMPLATE (PRODUCTION)
# =============================================================================

# Port d'écoute du serveur
PORT=3000

# Base de Données MySQL (Production ou Locale)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=yool_station_db

# Sécurité SSO (JWT)
# -----------------
# JWT_SECRET : Clé secrète de 64 caractères recommandés
JWT_SECRET=super_secret_jwt_key_yool_platform_2024_secret_key
JWT_AUDIENCE=yool-platform

# Intégration Module 1 (Backend Principal)
# ----------------------------------------
MODULE1_API_URL=http://localhost:8000/api
MODULE1_SERVER_SECRET=your_server_to_server_secret_key

# Synchronisation de Déconnexion (Webhook)
# ----------------------------------------
# URL du endpoint SSO Logout sur la plateforme Laravel
PLATFORM_LOGOUT_URL=http://localhost:8000/api/sso/logout

# Paramètres de la Station par défaut
DEFAULT_STATION_LOCATION=Hall Principal

# Configuration Système
NODE_ENV=production
LOG_LEVEL=info
