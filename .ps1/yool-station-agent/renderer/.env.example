# Configuration Client YOOL Station Agent

# URL du serveur YOOL Station Server
VITE_API_URL=http://localhost:3000/api

# URL du backend qui verifie les cartes (si differente)
VITE_VERIFY_API_URL=http://localhost:3000/api

# Active la verification carte avant session
VITE_USE_VERIFY_API=true

# Token JWT/Bearer pour /cards/verify si requis
VITE_VERIFY_API_TOKEN=

# Identifiant unique de ce poste
VITE_STATION_ID=STATION_001

# Legacy non-Vite key (kept for compatibility)
STATION_ID=STATION_001
# Cle secrete pour signature interne (facultatif si uniquement JWT serveur)
CLIENT_SECRET=change_me_client_secret

# Timeout de verrouillage (minutes)
INACTIVITY_TIMEOUT=15

# Mode de dev
NODE_ENV=development
